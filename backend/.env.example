# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=relihub
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/relihub

# Redis & Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Application Settings
ENVIRONMENT=local
PROJECT_NAME=ReliHub
API_V1_STR=/api/v1
SECRET_KEY=super-secret-key-change-me
PHONE_BLIND_INDEX_KEY=independent-blind-index-key-change-me

# Tencent Cloud COS
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_REGION=ap-shanghai
COS_BUCKET=relihub-resources
COS_ENDPOINT=https://cos.ap-shanghai.myqcloud.com
