      "danger": {
        "variants": ["large", "medium", "small"],
        "states": ["default", "hover", "active", "disabled"],
        "properties": {
          "default": {
            "background": "#FF3B30",
            "text": "#FFFFFF"
          }
        }
      }
    },
    
    "inputs": {
      "text": {
        "variants": ["with_icon", "with_label", "with_helper", "multiline"],
        "states": ["default", "focus", "filled", "disabled", "error", "success"],
        "properties": {
          "default": {
            "height": 40,
            "padding": "12px 16px",
            "border": "1px solid #E0E0E0",
            "border_radius": 8,
            "background": "#FFFFFF",
            "font_size": 14
          },
          "focus": {
            "border": "2px solid #007AFF",
            "shadow": "0 0 0 3px rgba(0,122,255,0.1)"
          },
          "error": {
            "border": "1px solid #FF3B30",
            "text_color": "#FF3B30"
          }
        }
      },
      "search": {
        "properties": {
          "background": "#F2F2F7",
          "border_radius": 20,
          "left_icon": "search"
        }
      },
      "select": {
        "properties": {
          "height": 40,
          "right_icon": "chevron_down"
        }
      },
      "checkbox": {
        "size": 20,
        "border": "2px solid #E0E0E0",
        "states": ["unchecked", "checked", "indeterminate", "disabled"]
      },
      "radio": {
        "size": 20,
        "border": "2px solid #E0E0E0",
        "states": ["unchecked", "checked", "disabled"]
      },
      "toggle": {
        "width": 52,
        "height": 32,
        "border_radius": 16,
        "states": ["off", "on", "disabled"]
      }
    },
    
    "cards": {
      "base": {
        "background": "#FFFFFF",
        "border": "1px solid #E0E0E0",
        "border_radius": 8,
        "padding": 16,
        "shadow": "0 1px 2px rgba(0,0,0,0.05)"
