  "components": {
    "buttons": {
      "primary": {
        "variants": ["large", "medium", "small"],
        "states": ["default", "hover", "active", "disabled", "loading"],
        "properties": {
          "default": {
            "background": "#007AFF",
            "text": "#FFFFFF",
            "border_radius": 8,
            "padding": "12px 20px",
            "font_size": 14
          },
          "hover": {
            "background": "#0051D5",
            "shadow": "sm"
          },
          "active": {
            "background": "#004399",
            "shadow": "none"
          },
          "disabled": {
            "background": "#D1D1D1",
            "text": "#999999",
            "cursor": "not-allowed"
          }
        }
      },
      "secondary": {
        "variants": ["large", "medium", "small"],
        "states": ["default", "hover", "active", "disabled"],
        "properties": {
          "default": {
            "background": "transparent",
            "border": "2px solid #007AFF",
